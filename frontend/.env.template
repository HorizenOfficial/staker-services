RPC=http://localhost:8545
CHAIN_ID=31337
CONTRACT_STAKER=0xcba6b9a951749b8735c603e7ffc5151849248772
CONTRACT_TOKEN=0x057ef64E23666F000b34aE31332854aCBd1c8544
SUBGRAPH=http://localhost:8000/subgraphs/name/zen-staker
# Block explorer base URL — used to build tx links (`<base>/tx/<hash>`) or other links to the explorer.
# Fake placeholder for local devnet (anvil has no explorer).
EXPLORER_URL=https://explorer.example.com
# Terms & Conditions URL, linked in the footer next to the block explorer link.
# Optional — defaults to https://horizen.io/ when unset.
TERMS_URL=
# Single-position UX: present one aggregated position and route "stake" to
# stakeMore on the existing deposit. Set to false to expose the multi-deposit
# model (needed once per-deposit delegation is surfaced).
SINGLE_POSITION=true
# Onboarding links shown in the dashboard hero ("Bridge ETH from Base" /
# "Bridge ZEN from Base"). Optional — left unset, the steps render as plain text.
BRIDGE_ETH_URL=
BRIDGE_ZEN_URL=
# CoinGecko coin id used to price the staked token in USD for the "Staked
# value" stat ("zencash" is correct for ZEN — CoinGecko kept the pre-rebrand
# slug, "horizen" does not exist as an id there). Leave blank to disable
# (e.g. on a devnet deploying a mock token, not real ZEN).
COINGECKO_ID=zencash
# Subgraph health check (useSubgraphHealth): block gap above which the
# subgraph is considered behind the chain head, how many consecutive polls it
# must stay over that gap before the "stale" banner is shown (absorbs
# transient lag), and the polling/retry interval in seconds. Defaults below
# apply if left unset — waits ~behindThresholdAttempt *
# behindThresholdAttemptInterval seconds (~2 min by default) before warning.
BEHIND_THRESHOLD=30
BEHIND_THRESHOLD_ATTEMPT=4
BEHIND_THRESHOLD_ATTEMPT_INTERVAL=30
